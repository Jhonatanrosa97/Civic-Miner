                    print("-" * 60)
                    
                    # ESTRATÉGIA: Procura por MUNICIPIO DE ou PREFEITURA (o que foi selecionado na Unidade Gestora)
                    print("\n🔍 Buscando linha com MUNICIPIO DE ou PREFEITURA...")
                    
                    for i, linha in enumerate(todas_as_linhas):
                        try:
                            texto_linha = linha.text.upper()
                            
                            print(f"  Linha [{i}]: {texto_linha[:80]}")
                            
                            # PRIMEIRO: Verifica se TEM termos de exclusão (FUNDO, SERVIÇO, etc)
                            tem_exclusao = any(x in texto_linha for x in [
                                "CAMARA", 
                                "CÂMARA",
                                "FUNDO",
                                "SECRETARIA",
                                "SERVICO",
                                "SERVIÇO",
                                "AUTONOMO",
                                "AUTÔNOMO"
                            ])
                            
                            if tem_exclusao:
                                print(f"    [ERRO] Rejeitada (tem FUNDO/SERVIÇO/SECRETARIA)")
                                continue
                            
                            # SEGUNDO: Procura por MUNICIPIO ou PREFEITURA
                            if "MUNICIPIO" in texto_linha or "PREFEITURA" in texto_linha:
                                print(f"    ✅ ENCONTRADA!")
                                linha_desejada = linha
                                break
                                
                        except Exception as e:
                            print(f"    Erro: {e}")
                            pass
                    
                    # Se não encontrou com os critérios, usa a primeira linha
                    if not linha_desejada and todas_as_linhas:
                        print("\n[AVISO]  Nenhuma linha com PREFEITURA/MUNICIPIO encontrada")
                        print("   Usando PRIMEIRA linha disponível como fallback...")
                        linha_desejada = todas_as_linhas[0]
                        print(f"   Linha selecionada: {linha_desejada.text[:120]}\n")
                    
                    # Encontra o botão de expandir (seta) nesta linha
                    if linha_desejada:
                        print("🔍 Procurando botão de expandir (seta) na linha selecionada...")
                        try:
                            # Procura por QUALQUER seta (up ou down) - vamos verificar depois
                            seta_btn = linha_desejada.find_element(
                                By.XPATH,
                                ".//span[contains(@class, 'fa-chevron')]"
                            )
                            
                            # Verifica se a linha está fechada ou aberta
                            classes_seta = seta_btn.get_attribute("class")
                            esta_fechada = "fa-chevron-down" in classes_seta
                            esta_aberta = "fa-chevron-up" in classes_seta
                            
                            if esta_fechada:
                                print("[OK] Linha está FECHADA - precisamos expandir!")
                            elif esta_aberta:
                                print("[AVISO]  Linha já está ABERTA - vamos clicar para FECHAR e depois ABRIR novamente")
                            
                            print(f"   Classes do botão: {classes_seta}\n")
                            
                        except Exception as e:
                            print(f"[ERRO] Erro ao encontrar botão de expandir: {e}\n")
                            seta_btn = None
                else:
                    print("[ERRO] Nenhuma linha de agrupamento encontrada!\n")
                    
            except Exception as e:
                print(f"\n[ERRO] Erro ao procurar linhas: {e}")
                traceback.print_exc()

            # ============================================================
            # Clica no botão para expandir/recarregar a linha
            # ============================================================
            if linha_desejada and seta_btn:
                try:
                    print("="*60)
                    print("EXPANDINDO A LINHA SELECIONADA")
                    print("="*60 + "\n")
                    
                    # Scroll até a linha
                    self.driver.execute_script("arguments[0].scrollIntoView({block:'center'});", seta_btn)
                    time.sleep(0.5)
                    
                    # Verifica se precisa clicar (se está fechada, clica para abrir)
                    classes_seta = seta_btn.get_attribute("class")
                    
                    # Se está aberta (chevron-up), clica para fechar primeiro
                    if "fa-chevron-up" in classes_seta:
                        print("Linha está ABERTA - fechando primeiro...")
                        try:
                            self.driver.execute_script("arguments[0].click();", seta_btn)
                            time.sleep(1)
                            print("[OK] Linha fechada\n")
                        except Exception as e:
                            print(f"Aviso: Erro ao fechar linha: {e}\n")
                    
                    # Agora clica para ABRIR (ou abre pela primeira vez)
                    print("Clicando para EXPANDIR a linha...")
                    try:
                        ActionChains(self.driver).move_to_element(seta_btn).pause(0.5).click().perform()
                        print("[OK] Clicado via ActionChains!\n")
                    except Exception as e1:
                        print(f"  ActionChains falhou: {str(e1)[:50]}")
                        print("  Tentando JavaScript...")
                        try:
                            self.driver.execute_script("arguments[0].click();", seta_btn)
                            print("[OK] Clicado via JavaScript!\n")
                        except Exception as e2:
                            print(f"[ERRO] JavaScript também falhou: {str(e2)[:50]}\n")
                            raise
                    
                    # Aguarda a linha expandir e os elementos carregarem
                    print("Aguardando linha expandir e contratos carregarem...")
                    time.sleep(2)
                    print("[OK] Linha expandida com sucesso!")
                    print("="*60 + "\n")
                    
                except Exception as e:
                    print(f"\n[ERRO] Erro ao expandir a linha: {e}")
                    traceback.print_exc()
                    raise
            else:
                erro_msg = "Não foi possível encontrar "
                if not linha_desejada:
                    erro_msg += "linha adequada"
                elif not seta_btn:
                    erro_msg += "botão de expansão"
                print(f"\n[ERRO] {erro_msg}\n")
                raise Exception(erro_msg)

        except Exception as e:
            print(f"\n[ERRO] Erro ao acessar o portal: {e}")
            traceback.print_exc()
            raise

    def clicar_linha_visualizacao(self, timeout=20):
        """
        Após a linha do contrato ser expandida, localiza a linha de detalhe correta e clica no ícone de visualização (olho).
        """
        wait = WebDriverWait(self.driver, timeout)

        print("\n" + "="*60)
        print("CLICANDO NO ÍCONE DE VISUALIZAÇÃO (OLHO)")
        print("="*60 + "\n")

        time.sleep(1)

        try:
            html_debug = os.path.join(
                os.path.abspath(os.path.join(os.path.dirname(__file__), "..")),
                "debug_linhas_expandidas.html"
            )
            with open(html_debug, "w", encoding="utf-8") as f:
                f.write(self.driver.page_source)
            print(f"HTML de debug salvo: {html_debug}\n")
        except Exception as e:
            print(f"Erro ao salvar HTML debug: {e}\n")

        print("Procurando por ícones de visualização (fa-eye)...")
        try:
            eye_icons = self.driver.find_elements(By.XPATH, "//i[contains(@class, 'fa-eye')] | //span[contains(@class, 'fa-eye')]")
            print(f"[OK] Encontrados {len(eye_icons)} ícones de olho na página\n")
            
            if len(eye_icons) > 0:
                print("Linhas com ícone de olho:")
                for i, eye in enumerate(eye_icons[:5]):
                    try:
                        parent_row = eye.find_element(By.XPATH, "ancestor::tr")
                        texto_linha = parent_row.text[:100]
                        print(f"  [{i}] {texto_linha}")
                    except:
                        pass
                print()
        except Exception as e:
            print(f"Erro ao listar ícones: {e}\n")

        rows = []
        print("Buscando linhas de detalhe...")
        
        try:
            rows = self.driver.find_elements(By.XPATH, "//tr[.//i[contains(@class, 'fa-eye')] or .//span[contains(@class, 'fa-eye')]]")
            print(f"[OK] {len(rows)} linhas encontradas com ícone de olho\n")
            
            if not rows:
                print("Tentando encontrar qualquer linha dentro da tabela...")
                rows = self.driver.find_elements(By.XPATH, "//tr[contains(@class, 'linha') or contains(@class, 'detail')]")
                print(f"[OK] {len(rows)} linhas encontradas (alternativo)\n")
                
        except Exception as e:
            print(f"✗ Erro ao encontrar linhas: {e}\n")
            return False

        if not rows:
            print("✗ Nenhuma linha de detalhe encontrada!")
            print("Tentando estratégia alternativa...")
            try:
                rows = self.driver.find_elements(By.XPATH, "//tr[not(contains(@class, 'agrupamento'))]")
                if rows:
                    print(f"[OK] Encontradas {len(rows)} linhas via estratégia alternativa\n")
                else:
                    return False
            except:
                return False

        print(f"Escolhendo primeira linha de {len(rows)} disponíveis...")
        chosen_row = rows[0]
        
        try:
            texto = chosen_row.text
            print(f"Texto da linha: {texto[:150] if texto else '[linha vazia]'}\n")
        except:
            print("[Não conseguiu obter texto da linha]\n")

        print("Fazendo scroll para linha...")
        self.driver.execute_script("arguments[0].scrollIntoView({block:'center'});", chosen_row)
        time.sleep(0.5)

        print("Procurando ícone de olho dentro da linha...")
        eye_icon = None
        try:
            eye_xpaths = [
                ".//i[contains(@class, 'fa-eye')]",
                ".//span[contains(@class, 'fa-eye')]",
                ".//button[.//i[contains(@class, 'fa-eye')]]",
                ".//a[.//i[contains(@class, 'fa-eye')]]",
            ]
            
            for xpath in eye_xpaths:
                try:
                    elements = chosen_row.find_elements(By.XPATH, xpath)
                    if elements:
                        eye_icon = elements[0]
                        print(f"[OK] Ícone encontrado com: {xpath}\n")
                        break
                except:
                    pass
        except Exception as e:
            print(f"Erro ao procurar ícone: {e}\n")

        if not eye_icon:
            print("[AVISO]  Ícone de olho não encontrado na linha!")
            print("Tentando encontrar dentro de colunas específicas...")
            try:
                tds = chosen_row.find_elements(By.XPATH, ".//td")
                for td in tds:
                    try:
                        eye_icon = td.find_element(By.XPATH, ".//i[contains(@class, 'fa-eye')] | .//span[contains(@class, 'fa-eye')]")
                        print(f"[OK] Ícone encontrado em td\n")
                        break
                    except:
                        pass
            except:
                pass

        if not eye_icon:
            print("✗ Ainda não conseguiu encontrar ícone!")
            print("Tentando clicar em qualquer elemento clicável da linha...")
            try:
                clickable = chosen_row.find_element(By.XPATH, ".//a | .//button | .//span[contains(@class, 'acao') or contains(@class, 'acoes')]")
                eye_icon = clickable
                print("[OK] Elemento clicável encontrado como alternativa\n")
            except:
                return False

        print("Tentando clicar no ícone de visualizar...")
        max_attempts = 3
        
        for attempt in range(max_attempts):
            try:
                print(f"Tentativa {attempt + 1}/{max_attempts}...")
                
                self.driver.execute_script("arguments[0].scrollIntoView({block:'center'});", eye_icon)
                time.sleep(0.2)
                
                try:
                    ActionChains(self.driver).move_to_element(eye_icon).pause(0.35).click().perform()
                    print(f"[OK] Clicado via ActionChains!\n")
                    time.sleep(1)
                    return True
                except Exception as e1:
                    print(f"  ActionChains falhou: {str(e1)[:50]}")
                    
                    try:
                        self.driver.execute_script("arguments[0].click();", eye_icon)
                        print("[OK] Clicado via JavaScript!\n")
                        time.sleep(1)
                        return True
                    except Exception as e2:
                        print(f"  JavaScript falhou: {str(e2)[:50]}")
                
                time.sleep(0.5)
                
            except Exception as e:
                print(f"Erro na tentativa {attempt + 1}: {e}")

        print("✗ Falha ao clicar no ícone após todas as tentativas\n")
        return False

    def clicar_aba_anexos(self, timeout=15):
        """
        Clica na aba "Anexos" dentro do diálogo de visualização do contrato.
        """
        wait = WebDriverWait(self.driver, timeout)
        try:
            print("\n" + "="*60)
            print("CLICANDO NA ABA ANEXOS")
            print("="*60 + "\n")
            
            print("Aguardando o diálogo carregar completamente...")
            time.sleep(3)
            
            # Tenta aguardar elementos de carregamento desaparecerem
            print("Verificando se há elementos de carregamento...")
            try:
                loading_elements = self.driver.find_elements(By.XPATH, "//*[contains(@class, 'loading') or contains(@class, 'spinner') or contains(@class, 'aguarde')]")
                if loading_elements:
                    print(f"Encontrados {len(loading_elements)} elementos de carregamento, aguardando desaparecerem...")
                    for elem in loading_elements:
                        try:
                            wait.until(EC.invisibility_of_element_located((By.XPATH, f"//*[contains(@class, '{elem.get_attribute('class')}')]")))
                        except:
                            pass
                    print("[OK] Elementos de carregamento desapareceram\n")
            except:
                pass
            
            time.sleep(1.5)
            
            print("Procurando pela aba 'Anexos'...")
            
            # XPaths para encontrar a aba Anexos
            anexos_xpaths = [
                "//a[contains(., 'Anexos')]",
                "//span[contains(., 'Anexos')]",
                "//*[contains(text(), 'Anexos')]",
                "//li[contains(., 'Anexos')]",
                "//*[@title='Anexos']",
            ]
            
            aba_anexos = None
            for xpath in anexos_xpaths:
                try:
                    elementos = self.driver.find_elements(By.XPATH, xpath)
                    for elem in elementos:
                        try:
                            if elem.is_displayed():
                                aba_anexos = elem
                                print(f"[OK] Aba 'Anexos' encontrada com: {xpath}\n")
                                break
                        except:
                            pass
                    if aba_anexos:
                        break
                except Exception as e:
                    pass
            
            if not aba_anexos:
                print("✗ Aba 'Anexos' não encontrada!")
                print("Tentando wait até que apareça...")
                try:
                    aba_anexos = wait.until(EC.presence_of_element_located((By.XPATH, "//*[contains(text(), 'Anexos')]")))
                    print("[OK] Aba 'Anexos' encontrada após esperar!\n")
                except:
                    print("✗ Timeout aguardando aba 'Anexos'\n")
                    return False
            
            print("Fazendo scroll para aba...")
            self.driver.execute_script("arguments[0].scrollIntoView({block:'center'});", aba_anexos)
            time.sleep(0.3)
            
            print("Clicando na aba 'Anexos'...")
            try:
                ActionChains(self.driver).move_to_element(aba_anexos).pause(0.3).click().perform()
                print("[OK] Clicado via ActionChains!\n")
            except Exception as e1:
                print(f"ActionChains falhou: {str(e1)[:50]}")
                try:
                    self.driver.execute_script("arguments[0].click();", aba_anexos)
                    print("[OK] Clicado via JavaScript!\n")
                except Exception as e2:
                    print(f"JavaScript falhou: {str(e2)[:50]}\n")
                    return False
            
            print("[OK] Aba 'Anexos' clicada com sucesso!")
            print("="*60 + "\n")
            time.sleep(2)
            return True
            
        except Exception as e:
            print(f"Erro em clicar_aba_anexos: {e}\n")
            traceback.print_exc()
            return False

    def baixar_pdf_impressao(self, timeout=15):
        """
        Encontra qualquer linha na tabela de Anexos, clica nos 3 pontos e depois em 'Baixar'.
        Aceita qualquer tipo de documento, não apenas 'Impressão'.
        """
        wait = WebDriverWait(self.driver, timeout)
        try:
            print("\n" + "="*60)
            print("BAIXANDO PDF DA TABELA DE ANEXOS")
            print("="*60 + "\n")
            
            print("Aguardando a tabela de Anexos carregar completamente...")
            time.sleep(3)
            
            # Salva screenshot antes de tudo
            try:
                screenshot_path = os.path.join(
                    os.path.abspath(os.path.join(os.path.dirname(__file__), "..")),
                    "debug_antes_clique_3pontos.png"
                )
                self.driver.save_screenshot(screenshot_path)
                print(f"Screenshot salvo: {screenshot_path}\n")
            except:
                pass
            
            # Tenta aguardar elementos de carregamento desaparecerem
            print("Verificando se há elementos de carregamento...")
            try:
                loading_elements = self.driver.find_elements(By.XPATH, "//*[contains(@class, 'loading') or contains(@class, 'spinner') or contains(@class, 'aguarde')]")
                if loading_elements:
                    print(f"Encontrados {len(loading_elements)} elementos de carregamento, aguardando desaparecerem...\n")
            except:
                pass
            
            time.sleep(1)
            
            print("Procurando por linhas na tabela de Anexos...")
            
            # Procura qualquer linha na tabela (não apenas "Impressão")
            # Tentativa 1: Procura por linha com "Impressão" primeiro (se existir)
            print("1. Procurando linha com 'Impressão'...")
            impressao_xpaths = [
                "//tr[contains(., 'Impressão')]",
                "//tr[contains(., 'Impressao')]",
                "//tr[.//td[contains(., 'Impressão')]]",
                "//tr[.//td[contains(., 'Impressao')]]",
            ]
            
            pdf_row = None
            for xpath in impressao_xpaths:
                try:
                    elementos = self.driver.find_elements(By.XPATH, xpath)
                    if elementos:
                        pdf_row = elementos[0]
                        print(f"[OK] Linha 'Impressão' encontrada!\n")
                        break
                except:
                    pass
            
            # Tentativa 2: Se não encontrou "Impressão", procura primeira linha com dados
            if not pdf_row:
                print("2. 'Impressão' não encontrada. Procurando primeira linha disponível...")
                try:
                    # Procura a primeira linha da tabela de anexos
                    table_rows = self.driver.find_elements(By.XPATH, "//table//tr[td]")
                    if table_rows:
                        # Ignora cabeçalhos e procura primeira linha com conteúdo
                        for row in table_rows:
                            try:
                                cells = row.find_elements(By.XPATH, "./td")
                                if len(cells) > 0 and row.text.strip():
                                    pdf_row = row
                                    print(f"[OK] Primeira linha da tabela encontrada!")
                                    print(f"  Conteúdo: {row.text[:100]}\n")
                                    break
                            except:
                                pass
                except:
                    pass
            
            if not pdf_row:
                print("✗ Nenhuma linha com dados encontrada na tabela!")
                print("Salvando HTML para debug...")
                try:
                    html_debug = os.path.join(
                        os.path.abspath(os.path.join(os.path.dirname(__file__), "..")),
                        "debug_html_sem_impressao.html"
                    )
                    with open(html_debug, "w", encoding="utf-8") as f:
                        f.write(self.driver.page_source)
                    print(f"HTML salvo: {html_debug}\n")
                except:
                    pass
                return False
            
            print("[OK] Linha encontrada!")
            print(f"Texto da linha: {pdf_row.text[:150]}\n")
            
            # Faz scroll para garantir visibilidade
            self.driver.execute_script("arguments[0].scrollIntoView({block:'center'});", pdf_row)
            time.sleep(0.5)
            
            print("Procurando pelos 3 pontos (menu) na linha...")
            
            # Debug: lista todos os elementos clicáveis na linha
            print("Debug: Procurando todos os botões/spans da linha...")
            try:
                todos_botoes = pdf_row.find_elements(By.XPATH, ".//*[self::button or self::i or self::span or self::a]")
                print(f"Encontrados {len(todos_botoes)} elementos clicáveis")
                for i, btn in enumerate(todos_botoes[-5:]):  # Mostra os últimos 5
                    try:
                        tag = btn.tag_name
                        classe = btn.get_attribute("class") or ""
                        texto = btn.text or ""
                        print(f"  [{i}] <{tag}> class='{classe}' text='{texto[:30]}'")
                    except:
                        pass
                print()
            except:
                pass
            
            # Procura pelos 3 pontos - tenta especificamente na última coluna
            menu_button_xpaths = [
                ".//td[last()]//button",  # Botão na última coluna
                ".//td[last()]//i",  # Ícone na última coluna
                ".//td[last()]//span",  # Span na última coluna
                ".//button[contains(@class, 'menu') or contains(@class, 'action') or contains(@class, 'dropdown')]",
                ".//i[contains(@class, 'fa-ellipsis') or contains(@class, 'fa-bars') or contains(@class, 'fa-dots')]",
                ".//button",  # Fallback: último botão
            ]
            
            menu_button = None
            for xpath in menu_button_xpaths:
                try:
                    elementos = pdf_row.find_elements(By.XPATH, xpath)
                    if elementos:
                        # Prefere o último elemento (deve estar no final da linha)
                        menu_button = elementos[-1]
                        print(f"[OK] Possível menu encontrado com: {xpath}\n")
                        break
                except:
                    pass
            
            if not menu_button:
                print("✗ Menu button não encontrado!\n")
                return False
            
            print("[OK] Menu button encontrado! Clicando...")
            
            # Tenta clicar de várias formas
            click_success = False
            
            # Tentativa 1: ActionChains
            try:
                print("Tentativa 1: ActionChains...")
                self.driver.execute_script("arguments[0].scrollIntoView({block:'center'});", menu_button)
                time.sleep(0.3)
                ActionChains(self.driver).move_to_element(menu_button).pause(0.3).click().perform()
                print("[OK] Clicado via ActionChains!\n")
                click_success = True
            except Exception as e1:
                print(f"✗ ActionChains falhou: {str(e1)[:50]}")
            
            # Tentativa 2: JavaScript direto
            if not click_success:
                try:
                    print("Tentativa 2: JavaScript click...")
                    self.driver.execute_script("arguments[0].click();", menu_button)
                    print("[OK] Clicado via JavaScript!\n")
                    click_success = True
                except Exception as e2:
                    print(f"✗ JavaScript falhou: {str(e2)[:50]}")
            
            # Tentativa 3: Focus + Enter
            if not click_success:
                try:
                    print("Tentativa 3: Focus + Enter...")
                    self.driver.execute_script("arguments[0].focus();", menu_button)
                    menu_button.send_keys(Keys.RETURN)
                    print("[OK] Ativado via Focus + Enter!\n")
                    click_success = True
                except Exception as e3:
                    print(f"✗ Focus + Enter falhou: {str(e3)[:50]}\n")
            
            if not click_success:
                print("✗ Nenhum método de clique funcionou!\n")
                return False
            
            print("[OK] Menu clicado! Aguardando menu abrir...")
            time.sleep(1.5)
            
            # Salva screenshot do menu aberto
            try:
                screenshot_path = os.path.join(
                    os.path.abspath(os.path.join(os.path.dirname(__file__), "..")),
                    "debug_menu_aberto.png"
                )
                self.driver.save_screenshot(screenshot_path)
                print(f"Screenshot do menu salvo: {screenshot_path}\n")
            except:
                pass
            
            # Procura pelo botão "Baixar"
            print("Procurando pelo botão 'Baixar'...")
            
            baixar_xpaths = [
                "//*[contains(text(), 'Baixar')]",
                "//*[normalize-space()='Baixar']",
                "//a[contains(., 'Baixar')]",
                "//button[contains(., 'Baixar')]",
                "//li[contains(., 'Baixar')]",
                "//*[contains(text(), 'Download')]",
            ]
            
            baixar_button = None
            for xpath in baixar_xpaths:
                try:
                    elementos = self.driver.find_elements(By.XPATH, xpath)
                    if elementos:
                        for elem in elementos:
                            try:
                                if elem.is_displayed():
                                    baixar_button = elem
                                    print(f"[OK] Botão 'Baixar' encontrado com: {xpath}")
                                    print(f"  Texto: '{elem.text}'\n")
                                    break
                            except:
                                pass
                        if baixar_button:
                            break
                except:
                    pass
            
            if not baixar_button:
                print("✗ Botão 'Baixar' não encontrado!")
                print("Salvando HTML com menu aberto...")
                try:
                    html_debug = os.path.join(
                        os.path.abspath(os.path.join(os.path.dirname(__file__), "..")),
                        "debug_html_menu_aberto.html"
                    )
                    with open(html_debug, "w", encoding="utf-8") as f:
                        f.write(self.driver.page_source)
                    print(f"HTML salvo: {html_debug}\n")
                except:
                    pass
                return False
            
            print("[OK] Botão 'Baixar' encontrado! Clicando...")
            
            self.driver.execute_script("arguments[0].scrollIntoView({block:'center'});", baixar_button)
            time.sleep(0.3)
            
            try:
                ActionChains(self.driver).move_to_element(baixar_button).pause(0.3).click().perform()
                print("[OK] Clicado via ActionChains!\n")
            except Exception as e1:
                print(f"✗ ActionChains falhou: {str(e1)[:50]}")
                try:
                    self.driver.execute_script("arguments[0].click();", baixar_button)
                    print("[OK] Clicado via JavaScript!\n")
                except Exception as e2:
                    print(f"✗ JavaScript falhou: {str(e2)[:50]}\n")
                    return False
            
            print("[OK] Botão 'Baixar' clicado! Download iniciado...")
            time.sleep(1)
            
            # Monitora a pasta para detectar novo arquivo
            downloads_folder = os.path.join(
                os.path.abspath(os.path.join(os.path.dirname(__file__), "..")),
                "Downloads_PDFs"
            )
            
            print(f"\nAguardando arquivo ser baixado em: {downloads_folder}")
            
            # Lista arquivos antes
            arquivos_antes = set(os.listdir(downloads_folder))
            
            # Aguarda até 10 segundos pelo novo arquivo
            for tentativa in range(10):
                time.sleep(1)
                arquivos_agora = set(os.listdir(downloads_folder))
                novos_arquivos = arquivos_agora - arquivos_antes
                
                if novos_arquivos:
                    print(f"\n[OK] Arquivo(s) baixado(s):")
                    for arquivo in novos_arquivos:
                        caminho_completo = os.path.join(downloads_folder, arquivo)
                        tamanho = os.path.getsize(caminho_completo)
                        print(f"  📄 {arquivo}")
                        print(f"  📊 Tamanho: {tamanho} bytes")
                        print(f"  📍 Caminho: {caminho_completo}")
                    break
                else:
                    print(f"  Aguardando... ({tentativa + 1}/10)")
            
            print("\n" + "="*60)
            print("SUCESSO! PDF baixado com sucesso!")
            print("="*60 + "\n")
            
            return True
            
        except Exception as e:
            print(f"\nErro em baixar_pdf_impressao: {e}\n")
            traceback.print_exc()
            return False


    def run(self):
        try:
            self.acessar_portal()
            ok = self.clicar_linha_visualizacao()
            if ok:
                print("[OK] Visualização aberta!\n")
                time.sleep(1)
                
                ok_anexos = self.clicar_aba_anexos()
                if ok_anexos:
                    print("[OK] Aba 'Anexos' aberta!\n")
                    
                    # Tenta baixar o PDF
                    ok_download = self.baixar_pdf_impressao()
                    
                    if ok_download:
                        print("\n" + "="*60)
                        print("PROCESSO CONCLUÍDO COM SUCESSO!")
                        print("Fechando navegador em 2 segundos...")
                        print("="*60 + "\n")
                        time.sleep(2)
                    else:
                        print("\n✗ Falha no download.")
                        print("Pressione Enter para fechar o navegador...")
                        input()
                else:
                    print("\n✗ Falha ao abrir a aba 'Anexos'.")
                    print("Pressione Enter para fechar o navegador...")
                    input()
            else:
                print("\n✗ Falha ao localizar/clicar a linha de visualização.")
                print("Pressione Enter para fechar o navegador...")
                input()
            
        except Exception as e:
            print(f"\n[ERRO] Erro no run: {e}\n")
            traceback.print_exc()
            print("Pressione Enter para fechar o navegador...")
            input()
        finally:
            try:
                self.driver.quit()
                print("\n[OK] Navegador fechado com sucesso!\n")
            except Exception:
                pass